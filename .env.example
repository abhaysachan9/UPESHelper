# ─── Gemini API ───────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Upstash Vector DB ─────────────────────────────────────────────────────────
UPSTASH_VECTOR_REST_URL=your_upstash_vector_rest_url_here
UPSTASH_VECTOR_REST_TOKEN=your_upstash_vector_rest_token_here

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ─── Crawler ───────────────────────────────────────────────────────────────────
# Mode: "sitemap" (auto-discover via sitemap.xml) or "urllist" (use MANUAL_URLS in crawl.js)
CRAWL_MODE=sitemap

# Used when CRAWL_MODE=sitemap — the sitemap.xml URL to start from
SITEMAP_URL=https://www.upes.ac.in/sitemap.xml

# Max number of pages to crawl (applies to both modes)
MAX_PAGES=100
